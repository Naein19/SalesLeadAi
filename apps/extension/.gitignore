# ════════════════════════════════════════════════════════════════════════════════
# apps/extension — Chrome Extension .gitignore
# ════════════════════════════════════════════════════════════════════════════════

# ── Secrets & Environment Variables ─────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Packed / Distributable Extension Files ────────────────────────────────────────
# These are generated artifacts — never commit packed extensions
*.crx
*.xpi
*.zip
*.pem                  # extension signing key — VERY sensitive, never commit!

# ── Build Outputs (if a build step is added later) ────────────────────────────────
dist/
build/
out/

# ── Dependencies (if npm is added later) ─────────────────────────────────────────
node_modules/

# ── Logs ─────────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*

# ── OS / Editor ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Misc ─────────────────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
